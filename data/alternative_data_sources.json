  "creditScoringFormula": {
    "description": "AI-based credit scoring using alternative data",
    "components": [
      {
        "factor": "Payment History (Utility + Rent)",
        "weight": 35,
        "calculation": "Regular payment percentage * consistency score"
      },
      {
        "factor": "Income/Revenue Stability",
        "weight": 25,
        "calculation": "Income regularity * employment/business duration"
      },
      {
        "factor": "Alternative Data Availability",
        "weight": 20,
        "calculation": "Number of verified data sources * quality score"
      },
      {
        "factor": "Digital Behavior",
        "weight": 15,
        "calculation": "UPI patterns + digital payment diversity"
      },
      {
        "factor": "Debt Obligations",
        "weight": 5,
        "calculation": "Debt-to-income ratio (negative factor)"
      }
    ],
    "scoreRange": "0-1000",
    "riskCategories": {
      "excellent": "850-1000",
      "good": "750-849",
      "fair": "650-749",
      "poor": "0-649"
    }
  },
