# Alternative Data API Configuration
# Phase 2: Real API Integration

# ============= BBPS (Bharat Bill Payment System) =============
# For utility bill verification
# Get API access: https://www.npci.org.in/what-we-do/bbps/api-access

BBPS_API_URL=https://api.bbps.npci.org.in/v1
BBPS_API_KEY=your_bbps_api_key_here
BBPS_CLIENT_ID=your_bbps_client_id_here

# ============= Account Aggregator Framework =============
# For UPI/Banking transaction verification
# RBI-approved: https://sahamati.org.in/join-sahamati/

AA_API_URL=https://api.sahamati.org.in/v1
AA_API_KEY=your_aa_api_key_here
AA_FIU_ID=your_fiu_id_here

# ============= GST Portal API =============
# For business verification and GST filing history
# Get API access: https://gstcouncil.gov.in/api-access

GST_API_URL=https://api.gstportal.gov.in/v1
GST_API_KEY=your_gst_api_key_here

# ============= EPFO (Employees' Provident Fund) =============
# For employment verification
# API access: https://www.epfindia.gov.in/

EPFO_API_URL=https://api.epfindia.gov.in/v1
EPFO_API_KEY=your_epfo_api_key_here

# ============= DigiLocker =============
# For document verification (education, identity)
# Get API access: https://digilocker.gov.in/

DIGILOCKER_API_URL=https://api.digitallocker.gov.in/v1
DIGILOCKER_CLIENT_ID=your_digilocker_client_id_here
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret_here

# ============= General Settings =============

# Verification mode: "auto", "live", "mock"
VERIFICATION_MODE=auto

# API timeout (seconds)
API_TIMEOUT=15

# Enable detailed logging
DEBUG_MODE=true

# ============= Instructions =============
#
# 1. Copy this file to `.env` in the backend directory
# 2. Fill in your API credentials (keep them secret!)
# 3. Set VERIFICATION_MODE:
#    - "auto": Automatically use live APIs if configured, else mock
#    - "live": Force live APIs (will fail if not configured)
#    - "mock": Always use mock verification (for development)
#
# 4. Restart the backend server to apply changes
#
# ============= Getting API Access =============
#
# BBPS:
#   - Visit: https://www.npci.org.in/
#   - Apply for BBPS biller aggregator access
#   - Estimated time: 2-4 weeks
#   - Cost: Varies based on volume
#
# Account Aggregator:
#   - Visit: https://sahamati.org.in/
#   - Register as Financial Information User (FIU)
#   - RBI approval required
#   - Estimated time: 4-8 weeks
#   - Cost: Setup fee + transaction charges
#
# GST Portal:
#   - Visit: https://gstcouncil.gov.in/
#   - Apply for API access as verified entity
#   - Requires GST registration
#   - Estimated time: 1-2 weeks
#
# ============= Security Notes =============
#
# - NEVER commit `.env` file to git
# - Keep API keys secret
# - Use environment variables in production
# - Rotate keys periodically
# - Monitor API usage for anomalies
#
