# Crededge Backend Environment Variables
# Copy this file to .env and fill in actual values

# ── Server ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# PORT=8000  (set via uvicorn CLI, not env)

# ── Database ─────────────────────────────────────────────────
# SQLite (default, zero config):
DATABASE_URL=sqlite:///./crededge.db

# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/crededge

# ── Admin Credentials ────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123   # Change this in production!

# ── JWT ──────────────────────────────────────────────────────
# MUST be changed in production - use: openssl rand -hex 32
JWT_SECRET=crededge-super-secret-key-CHANGE-IN-PRODUCTION

# ── ML Model ─────────────────────────────────────────────────
# Set to true only after running: cd ml_models && python run_training_pipeline.py
USE_ML_MODEL=false
